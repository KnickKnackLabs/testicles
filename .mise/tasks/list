#!/usr/bin/env bash
#MISE description="List known keys in the local keyring"
#USAGE flag "--json" help="Output as JSON"
#USAGE flag "--secret" help="Only keys with a private key available"
#USAGE flag "--public" help="Only keys without a private key"
#USAGE arg "[pattern]" help="Filter by UID (name, email, domain)"
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"
require_gpg

# Build a newline-separated list of fingerprints that have secret keys
secret_fprs=""
while IFS= read -r line; do
  [ -z "$line" ] && continue
  type=$(echo "$line" | awk -F: '{ print $1 }')
  if [ "$type" = "sec" ]; then
    get_fpr=true
  elif [ "$type" = "fpr" ] && [ "${get_fpr:-}" = "true" ]; then
    fpr=$(echo "$line" | awk -F: '{ print $10 }')
    secret_fprs="$secret_fprs$fpr
"
    get_fpr=false
  fi
done < <(gpg --batch --with-colons --list-secret-keys 2>/dev/null || true)

# Parse all public keys
keys=()
while IFS= read -r line; do
  [ -z "$line" ] && continue
  type=$(echo "$line" | awk -F: '{ print $1 }')
  case "$type" in
    pub)
      created_ts=$(echo "$line" | awk -F: '{ print $6 }')
      expires_ts=$(echo "$line" | awk -F: '{ print $7 }')
      get_fpr=true
      ;;
    fpr)
      if [ "${get_fpr:-}" = "true" ]; then
        fingerprint=$(echo "$line" | awk -F: '{ print $10 }')
        get_fpr=false
      fi
      ;;
    uid)
      uid=$(echo "$line" | awk -F: '{ print $10 }')

      # Pattern filter
      if [ -n "${usage_pattern:-}" ]; then
        if ! echo "$uid" | grep -qi "$usage_pattern"; then
          continue
        fi
      fi

      # Determine if secret key exists
      has_secret=""
      if echo "$secret_fprs" | grep -q "^${fingerprint}$"; then
        has_secret="true"
      fi

      # Secret/public filter
      if [ "${usage_secret:-}" = "true" ] && [ -z "$has_secret" ]; then
        continue
      fi
      if [ "${usage_public:-}" = "true" ] && [ -n "$has_secret" ]; then
        continue
      fi

      # Format dates
      if [ -n "$created_ts" ] && [ "$created_ts" != "0" ]; then
        created=$(date -r "$created_ts" "+%Y-%m-%d" 2>/dev/null || date -d "@$created_ts" "+%Y-%m-%d" 2>/dev/null || echo "unknown")
      else
        created="unknown"
      fi
      if [ -n "$expires_ts" ] && [ "$expires_ts" != "0" ]; then
        expires=$(date -r "$expires_ts" "+%Y-%m-%d" 2>/dev/null || date -d "@$expires_ts" "+%Y-%m-%d" 2>/dev/null || echo "unknown")
      else
        expires="never"
      fi

      short_fpr="${fingerprint: -16}"
      secret_display=""
      if [ -n "$has_secret" ]; then
        secret_display="✓"
      fi

      # Parse UID into name and email
      parse_uid "$uid"

      if [ "${usage_json:-}" = "true" ]; then
        # Escape double quotes in name for JSON safety
        json_name=$(echo "$PARSED_NAME" | sed 's/"/\\"/g')
        keys+=("{\"fingerprint\":\"$fingerprint\",\"name\":\"$json_name\",\"email\":\"$PARSED_EMAIL\",\"secret\":$( [ -n "$has_secret" ] && echo "true" || echo "false"),\"created\":\"$created\",\"expires\":\"$expires\"}")
      else
        keys+=("$short_fpr"$'\t'"$PARSED_NAME"$'\t'"$PARSED_EMAIL"$'\t'"$secret_display"$'\t'"$created"$'\t'"$expires")
      fi
      ;;
  esac
done < <(gpg --batch --with-colons --list-keys 2>/dev/null)

if [ "${usage_json:-}" = "true" ]; then
  printf '['
  for i in "${!keys[@]}"; do
    [ "$i" -gt 0 ] && printf ','
    printf '%s' "${keys[$i]}"
  done
  printf ']\n'
else
  if [ ${#keys[@]} -eq 0 ]; then
    echo "No keys found."
    exit 0
  fi

  header="Key ID"$'\t'"Name"$'\t'"Email"$'\t'"Secret"$'\t'"Created"$'\t'"Expires"
  output=$(printf '%s\n' "$header" "${keys[@]}")
  echo "$output" | gum table -s $'\t' -p
fi
