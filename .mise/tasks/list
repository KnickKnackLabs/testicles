#!/usr/bin/env bash
#MISE description="List known keys in the local keyring"
#USAGE flag "--json" help="Output as JSON"
#USAGE flag "--secret" help="Only keys with a private key available"
#USAGE flag "--public" help="Only keys without a private key"
#USAGE arg "[pattern]" help="Filter by UID (name, email, domain)"
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"
require_gpg

# Collect all primary key fingerprints
fingerprints=$(gpg --batch --with-colons --list-keys 2>/dev/null \
  | awk -F: '/^pub:/ { getfpr=1; next } /^fpr:/ && getfpr { print $10; getfpr=0 }')

keys=()

while IFS= read -r fpr; do
  [ -z "$fpr" ] && continue

  query_key_meta "$fpr"
  query_key_uids "$fpr"

  # Check secret key status once per primary key
  has_secret=""
  if has_secret_key "$fpr"; then
    has_secret="true"
  fi

  # Secret/public filter (applied per key, before UID iteration)
  if [ "${usage_secret:-}" = "true" ] && [ -z "$has_secret" ]; then
    continue
  fi
  if [ "${usage_public:-}" = "true" ] && [ -n "$has_secret" ]; then
    continue
  fi

  short_fpr="${fpr: -16}"
  secret_display=""
  [ -n "$has_secret" ] && secret_display="✓"

  for uid in ${KEY_UIDS[@]+"${KEY_UIDS[@]}"}; do
    # Pattern filter
    if [ -n "${usage_pattern:-}" ]; then
      if ! echo "$uid" | grep -qi "$usage_pattern"; then
        continue
      fi
    fi

    parse_uid "$uid"

    if [ "${usage_json:-}" = "true" ]; then
      is_secret=$( [ -n "$has_secret" ] && echo "true" || echo "false")
      keys+=("$(jq -n \
        --arg fpr "$fpr" \
        --arg name "$PARSED_NAME" \
        --arg email "$PARSED_EMAIL" \
        --argjson secret "$is_secret" \
        --arg created "$KEY_CREATED" \
        --arg expires "$KEY_EXPIRES" \
        '{fingerprint: $fpr, name: $name, email: $email, secret: $secret, created: $created, expires: $expires}')")
    else
      keys+=("$short_fpr"$'\t'"$PARSED_NAME"$'\t'"$PARSED_EMAIL"$'\t'"$secret_display"$'\t'"$KEY_CREATED"$'\t'"$KEY_EXPIRES")
    fi
  done
done <<< "$fingerprints"

if [ "${usage_json:-}" = "true" ]; then
  if [ ${#keys[@]} -eq 0 ]; then
    echo '[]'
  else
    printf '%s\n' "${keys[@]}" | jq -s '.'
  fi
else
  if [ ${#keys[@]} -eq 0 ]; then
    echo "No keys found."
    exit 0
  fi

  header="Key ID"$'\t'"Name"$'\t'"Email"$'\t'"Secret"$'\t'"Created"$'\t'"Expires"
  output=$(printf '%s\n' "$header" "${keys[@]}")
  echo "$output" | gum table -s $'\t' -p
fi
