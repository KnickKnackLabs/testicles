#!/usr/bin/env bash
#MISE description="Export a key (armored)"
#USAGE flag "--first" help="Auto-select first match when multiple keys match"
#USAGE flag "--secret" help="Export the secret (private) key — DANGEROUS"
#USAGE flag "--public" help="Export the public key (default)"
#USAGE flag "--passphrase-file <path>" help="Read passphrase from file (for passphrase-protected secret keys)"
#USAGE arg "<identifier>" help="Email, fingerprint, or key ID"
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"
require_gpg

[ "${usage_first:-}" = "true" ] && export RESOLVE_FIRST=true

# Mutually exclusive
if [ "${usage_secret:-}" = "true" ] && [ "${usage_public:-}" = "true" ]; then
  echo "Error: --secret and --public are mutually exclusive" >&2
  exit 1
fi

fingerprint=$(resolve_key "$usage_identifier")

if [ "${usage_secret:-}" = "true" ]; then
  # Verify secret key exists before printing warnings
  if ! has_secret_key "$fingerprint"; then
    echo "Error: no secret key for $fingerprint" >&2
    exit 1
  fi

  # Warn loudly on stderr — stdout is the armored key, which may be piped
  echo "⚠  WARNING: exporting SECRET key — treat the output as highly sensitive." >&2
  echo "⚠  Fingerprint: $(format_fingerprint "$fingerprint")" >&2
  echo "" >&2

  build_passphrase_args
  gpg --batch --armor "${PASSPHRASE_ARGS[@]}" \
    --export-secret-keys "$fingerprint"
else
  gpg --batch --armor --export "$fingerprint"
fi
