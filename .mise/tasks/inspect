#!/usr/bin/env bash
#MISE description="Show key details and certifications"
#USAGE flag "--json" help="Output as JSON"
#USAGE flag "--first" help="Auto-select first match when multiple keys match"
#USAGE arg "<identifier>" help="Email, fingerprint, or key ID"
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"
require_gpg

[ "${usage_first:-}" = "true" ] && export RESOLVE_FIRST=true

fingerprint=$(resolve_key "$usage_identifier")

# --- Query all key data ---
query_key_meta "$fingerprint"
query_key_uids "$fingerprint"
query_key_subkeys "$fingerprint"
query_key_certifications "$fingerprint"

secret=""
if has_secret_key "$fingerprint"; then
  secret="true"
fi

# --- Output ---

if [ "${usage_json:-}" = "true" ]; then
  # Build UIDs JSON array
  uids_json="[]"
  for uid in ${KEY_UIDS[@]+"${KEY_UIDS[@]}"}; do
    parse_uid "$uid"
    uids_json=$(echo "$uids_json" | jq \
      --arg name "$PARSED_NAME" \
      --arg email "$PARSED_EMAIL" \
      '. + [{name: $name, email: $email}]')
  done

  # Build subkeys JSON array
  subkeys_json="[]"
  for sk in ${KEY_SUBKEYS[@]+"${KEY_SUBKEYS[@]}"}; do
    sk_id=$(echo "$sk" | cut -f1)
    sk_algo=$(echo "$sk" | cut -f2)
    sk_usage=$(echo "$sk" | cut -f3)
    sk_created=$(echo "$sk" | cut -f4)
    sk_expires=$(echo "$sk" | cut -f5)
    subkeys_json=$(echo "$subkeys_json" | jq \
      --arg id "$sk_id" \
      --arg algorithm "$sk_algo" \
      --arg usage "$sk_usage" \
      --arg created "$sk_created" \
      --arg expires "$sk_expires" \
      '. + [{id: $id, algorithm: $algorithm, usage: $usage, created: $created, expires: $expires}]')
  done

  # Build certifications JSON array
  certs_json="[]"
  for cert in ${KEY_CERTS[@]+"${KEY_CERTS[@]}"}; do
    cert_signer=$(echo "$cert" | cut -f1)
    cert_date=$(echo "$cert" | cut -f2)
    parse_uid "$cert_signer"
    certs_json=$(echo "$certs_json" | jq \
      --arg name "$PARSED_NAME" \
      --arg email "$PARSED_EMAIL" \
      --arg date "$cert_date" \
      '. + [{name: $name, email: $email, date: $date}]')
  done

  is_secret=$( [ -n "$secret" ] && echo "true" || echo "false")
  jq -n \
    --arg fingerprint "$fingerprint" \
    --arg algorithm "$KEY_ALGO" \
    --argjson secret "$is_secret" \
    --arg created "$KEY_CREATED" \
    --arg expires "$KEY_EXPIRES" \
    --argjson uids "$uids_json" \
    --argjson subkeys "$subkeys_json" \
    --argjson certifications "$certs_json" \
    '{fingerprint: $fingerprint, algorithm: $algorithm, secret: $secret, created: $created, expires: $expires, uids: $uids, subkeys: $subkeys, certifications: $certifications}'
else
  # Human-readable output
  secret_display="no"
  [ -n "$secret" ] && secret_display="✓"

  gum style --bold "Key Details"
  echo "  Fingerprint: $(format_fingerprint "$fingerprint")"
  echo "  Algorithm:   $KEY_ALGO"
  echo "  Created:     $KEY_CREATED"
  echo "  Expires:     $KEY_EXPIRES"
  echo "  Secret:      $secret_display"

  echo ""
  gum style --bold "UIDs"
  for uid in ${KEY_UIDS[@]+"${KEY_UIDS[@]}"}; do
    echo "  $uid"
  done

  if [ ${#KEY_SUBKEYS[@]} -gt 0 ]; then
    echo ""
    gum style --bold "Subkeys"
    header="Key ID"$'\t'"Algorithm"$'\t'"Usage"$'\t'"Created"$'\t'"Expires"
    output=$(printf '%s\n' "$header" "${KEY_SUBKEYS[@]}")
    echo "$output" | gum table -s $'\t' -p
  fi

  if [ ${#KEY_CERTS[@]} -gt 0 ]; then
    echo ""
    gum style --bold "Certifications"
    header="Signed by"$'\t'"Date"
    output=$(printf '%s\n' "$header" "${KEY_CERTS[@]}")
    echo "$output" | gum table -s $'\t' -p
  else
    echo ""
    echo "  No certifications found locally."
  fi
fi
